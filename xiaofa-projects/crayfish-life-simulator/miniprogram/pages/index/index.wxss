/* index.wxss */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.container {
  padding: 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.title-card {
  margin-top: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
}

.title {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 30rpx;
  color: #888;
}

.attrs-card {
  background: rgba(255,255,255,0.95);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.attr-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.attr-item:last-child {
  border-bottom: none;
}

.attr-label {
  font-size: 32rpx;
  color: #555;
  font-weight: 500;
}

.attr-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
}

.reroll-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  padding: 20rpx 40rpx;
  box-shadow: 0 5rpx 15rpx rgba(245,87,108,0.3);
}

.start-btn {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 38rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(79,172,254,0.4);
}

.setting-btn {
  background: rgba(255,255,255,0.9);
  color: #666;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 30rpx;
  border: none;
  box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

/* 广告位预留样式 */
.ad-slot {
  height: 120rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #aaa;
}

.ad-placeholder {
  font-size: 26rpx;
  color: #999;
}
