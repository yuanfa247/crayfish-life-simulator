/* index.wxss */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.container {
  padding: 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.title-card {
  margin-top: 20rpx;
  text-align: center;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 25rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
}

.title {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 30rpx;
  color: #888;
  margin-bottom: 10rpx;
}

.step-indicator {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 500;
}

.attrs-card {
  background: rgba(255,255,255,0.95);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 15rpx;
}

.back-btn.hidden {
  display: none;
}

.back-icon {
  font-size: 32rpx;
  color: #666;
  font-weight: bold;
}

.card-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.attr-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.attr-item:last-child {
  border-bottom: none;
}

.attr-label {
  font-size: 36rpx;
  color: #555;
  font-weight: 500;
}

.attr-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ctrl-btn {
  width: 60rpx !important;
  height: 60rpx !important;
  padding: 0 !important;
  line-height: 60rpx !important;
  font-size: 36rpx !important;
  border-radius: 50% !important;
  background: #f0f0f0 !important;
  color: #333 !important;
  border: none !important;
  margin: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  min-width: unset !important;
  box-shadow: none !important;
}

.ctrl-btn[disabled] {
  background: #f8f8f8 !important;
  color: #ccc !important;
}

.attr-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  min-width: 60rpx;
  text-align: center;
}

.reroll-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  border-radius: 40rpx;
  font-size: 32rpx;
  border: none;
  padding: 25rpx 50rpx;
  box-shadow: 0 5rpx 15rpx rgba(245,87,108,0.3);
  margin-bottom: 15rpx;
}

.next-step-btn, .prev-step-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 40rpx;
  font-size: 32rpx;
  border: none;
  padding: 25rpx 50rpx;
  box-shadow: 0 5rpx 15rpx rgba(102,126,234,0.3);
  margin-bottom: 15rpx;
}

/* 天赋选择样式 */
.talent-card {
  background: rgba(255,255,255,0.95);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
  flex: 1;
  overflow-y: auto;
}

.talent-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  border: 2rpx solid transparent;
}

/* 天赋等级样式 */
.talent-item.level-0 { border-left: 8rpx solid #757575; } /* 白板 */
.talent-item.level-1 { border-left: 8rpx solid #388e3c; } /* 绿色 */
.talent-item.level-2 { border-left: 8rpx solid #1976d2; } /* 蓝色 */
.talent-item.level-3 { border-left: 8rpx solid #7b1fa2; } /* 紫色 */
.talent-item.level-4 { border-left: 8rpx solid #f57c00; } /* 橙色 */
.talent-item.level-5 { border-left: 8rpx solid #d32f2f; } /* 红色 */

.talent-item.selected {
  background: #e8f5e9;
  border-color: #4caf50;
  box-shadow: 0 0 0 2rpx rgba(76,175,80,0.3);
}

.talent-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 5rpx;
}

.talent-level {
  font-size: 24rpx;
  font-weight: bold;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  color: white;
}

.level-text-0 { background: #9e9e9e; }
.level-text-1 { background: #4caf50; }
.level-text-2 { background: #2196f3; }
.level-text-3 { background: #9c27b0; }
.level-text-4 { background: #ff9800; }
.level-text-5 { background: #f44336; }

.talent-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.talent-desc {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.talent-effect {
  font-size: 28rpx;
  color: #4caf50;
  font-weight: 500;
}

.start-btn {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
  border-radius: 50rpx;
  padding: 40rpx;
  font-size: 42rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  border: none;
  box-shadow: 0 10rpx 25rpx rgba(79,172,254,0.4);
}

.talent-start-btn[disabled] {
  background: #ccc !important;
  color: #999 !important;
  box-shadow: none !important;
}

.talent-tip {
  font-size: 24rpx;
  color: #fff;
  text-align: center;
  margin-bottom: 20rpx;
  opacity: 0.8;
}

.setting-btn {
  background: rgba(255,255,255,0.9);
  color: #666;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 30rpx;
  border: none;
  box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.1);
}

page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  height: auto;
  overflow: auto;
}
