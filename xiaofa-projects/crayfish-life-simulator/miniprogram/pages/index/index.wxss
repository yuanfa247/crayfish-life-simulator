/* index.wxss */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.container {
  padding: 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.title-card {
  margin-top: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
}

.title {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 30rpx;
  color: #888;
  margin-bottom: 10rpx;
}

.step-indicator {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 500;
}

.attrs-card {
  background: rgba(255,255,255,0.95);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.attr-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.attr-item:last-child {
  border-bottom: none;
}

.attr-label {
  font-size: 32rpx;
  color: #555;
  font-weight: 500;
}

.attr-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ctrl-btn {
  width: 60rpx;
  height: 60rpx;
  padding: 0;
  line-height: 60rpx;
  font-size: 36rpx;
  border-radius: 50%;
  background: #f0f0f0;
  color: #333;
  border: none;
}

.ctrl-btn[disabled] {
  background: #f8f8f8;
  color: #ccc;
}

.attr-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  min-width: 60rpx;
  text-align: center;
}

.reroll-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  padding: 20rpx 40rpx;
  box-shadow: 0 5rpx 15rpx rgba(245,87,108,0.3);
  margin-bottom: 10rpx;
}

.next-step-btn, .prev-step-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  padding: 20rpx 40rpx;
  box-shadow: 0 5rpx 15rpx rgba(102,126,234,0.3);
}

/* 天赋选择样式 */
.talent-card {
  background: rgba(255,255,255,0.95);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
  flex: 1;
  overflow-y: auto;
}

.talent-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  border: 2rpx solid transparent;
}

.talent-item.selected {
  background: #e8f5e9;
  border-color: #4caf50;
}

.talent-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.talent-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.talent-effect {
  font-size: 22rpx;
  color: #4caf50;
  font-weight: 500;
}

.start-btn {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 38rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(79,172,254,0.4);
}

.setting-btn {
  background: rgba(255,255,255,0.9);
  color: #666;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 30rpx;
  border: none;
  box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.1);
}

page {
  overflow: hidden;
}
