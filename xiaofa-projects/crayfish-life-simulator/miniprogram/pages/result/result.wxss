/* pages/result/result.wxss */
.container {
  min-height: 100vh;
  padding: 30rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
}

.ending-card {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.ending-emoji {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.ending-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
}

.ending-desc {
  font-size: 30rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.final-stats {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.stat-item {
  padding: 0 40rpx;
  border-right: 1rpx solid #eee;
}

.stat-item:last-child {
  border-right: none;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #4A90E2;
}

.attributes-summary {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.attr-tag {
  background-color: #f0f7ff;
  color: #4A90E2;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.ending-conclusion {
  font-size: 28rpx;
  color: #52c41a;
  line-height: 1.8;
  padding: 20rpx;
  background-color: #f6ffed;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
}

.actions {
  display: flex;
  flex-direction: column;
}

.btn {
  font-size: 32rpx;
  padding: 25rpx 0;
  border-radius: 50rpx;
  margin-bottom: 20rpx;
  border: none;
}

.btn:last-child {
  margin-bottom: 0;
}

.btn-primary {
  background-color: #4A90E2;
  color: #fff;
}

.btn-default {
  background-color: #f0f0f0;
  color: #666;
}

.btn::after {
  border: none;
}
