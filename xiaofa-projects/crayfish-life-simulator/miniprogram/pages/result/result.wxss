/* pages/result/result.wxss */
.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  background-color: #f5f5f5;
}

.result-card {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.emoji {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 50rpx;
}

.stat-item {
  text-align: center;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #4A90E2;
}

.achievements {
  margin-bottom: 50rpx;
  text-align: left;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.achievement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.achievement-item:last-child {
  margin-bottom: 0;
}

.achievement-name {
  font-size: 28rpx;
  color: #333;
}

.achievement-name.locked {
  color: #999;
  text-decoration: line-through;
}

.actions {
  display: flex;
  flex-direction: column;
}

.btn {
  font-size: 32rpx;
  padding: 25rpx 0;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  border: none;
}

.btn:last-child {
  margin-bottom: 0;
}

.btn-primary {
  background-color: #4A90E2;
  color: #fff;
}

.btn-default {
  background-color: #f0f0f0;
  color: #666;
}

.btn::after {
  border: none;
}
