<!--pages/result/result.wxml-->
<view class="container">
  <view class="ending-card">
    <view class="ending-emoji">{{ending.image}}</view>
    <view class="ending-title">{{ending.title}}</view>
    <view class="ending-desc">{{ending.description}}</view>

    <view class="final-stats">
      <view class="stat-item">
        <text class="stat-label">最终年龄</text>
        <text class="stat-value">{{age}}岁</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">总评分</text>
        <text class="stat-value">{{totalScore}}</text>
      </view>
    </view>

    <view class="attributes-summary">
      <view class="attr-tag" wx:for="{{attributes}}" wx:key="key">
        {{index}}: {{item}}
      </view>
    </view>

    <view class="ending-conclusion">
      {{ending.endingText.replace('{{age}}', age)}}
    </view>

    <view class="actions">
      <button class="btn btn-primary" bindtap="restart">重新开始</button>
      <button class="btn btn-default" bindtap="backHome">返回首页</button>
    </view>
  </view>
</view>
