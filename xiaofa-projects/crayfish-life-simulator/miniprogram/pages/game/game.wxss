/* pages/game/game.wxss */
.container {
  min-height: 100vh;
  padding: 20rpx;
  background-color: #f5f5f5;
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.game-header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.game-header .level {
  font-size: 28rpx;
  color: #4A90E2;
  background-color: #e6f4ff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.attributes-panel {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.attr-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.attr-item:last-child {
  margin-bottom: 0;
}

.attr-name {
  width: 100rpx;
  font-size: 26rpx;
  color: #666;
}

.attr-bar {
  flex: 1;
  height: 24rpx;
  background-color: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
  margin: 0 20rpx;
}

.attr-fill {
  height: 100%;
  transition: width 0.3s;
}

.attr-value {
  width: 60rpx;
  font-size: 26rpx;
  color: #333;
  text-align: right;
}

.pet-image {
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 100rpx 0;
  margin-bottom: 30rpx;
}

.pet-placeholder {
  font-size: 200rpx;
}

.actions-panel {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.action-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.action-row:last-child {
  margin-bottom: 0;
}

.action-btn {
  width: 48%;
  font-size: 30rpx;
  padding: 25rpx 0;
  background-color: #4A90E2;
  color: #fff;
  border: none;
  border-radius: 12rpx;
}

.action-btn::after {
  border: none;
}
