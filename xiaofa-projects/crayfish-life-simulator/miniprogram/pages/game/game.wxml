<!--pages/game/game.wxml-->
<view class="container">
  <!-- 状态栏：年龄和属性总览 -->
  <view class="status-bar">
    <view class="age-info">
      <text class="age">年龄: {{age}}岁</text>
      <text class="age-stage">[{{ageStage}}]</text>
    </view>
    <view class="event-count">经历: {{eventCount}}件事</view>
  </view>

  <!-- 属性面板 -->
  <view class="attributes-panel">
    <view class="attr-row">
      <view class="attr-item">
        <text class="attr-label">活力</text>
        <text class="attr-value">{{attributes.vitality}}</text>
      </view>
      <view class="attr-item">
        <text class="attr-label">智力</text>
        <text class="attr-value">{{attributes.intelligence}}</text>
      </view>
      <view class="attr-item">
        <text class="attr-label">财富</text>
        <text class="attr-value">{{attributes.wealth}}</text>
      </view>
    </view>
    <view class="attr-row">
      <view class="attr-item">
        <text class="attr-label">运气</text>
        <text class="attr-value">{{attributes.luck}}</text>
      </view>
      <view class="attr-item">
        <text class="attr-label">魅力</text>
        <text class="attr-value">{{attributes.charm}}</text>
      </view>
      <view class="attr-item empty"></view>
    </view>
  </view>

  <!-- 等待事件状态已移除，直接加载事件数据 -->

  <!-- 事件展示状态 -->
  <view wx:if="{{status === 'event'}}" class="event-panel">
    <view class="event-title">{{currentEvent.title}}</view>
    <view class="event-desc">{{currentEvent.description}}</view>

    <!-- 选择结果展示：普通事件点击整个面板都能继续 -->
    <view wx:if="{{showResult && !isEndingPending}}" class="result-panel" bindtap="skipResult">
      <view class="result-text">{{eventResult}}</view>
      <view class="attr-changes" wx:if="{{attrChanges.length > 0}}">
        <view class="attr-change-item {{item.delta > 0 ? 'add' : 'sub'}}" wx:for="{{attrChanges}}" wx:key="name">
          {{item.name}} {{item.delta > 0 ? '+' : ''}}{{item.delta}}
        </view>
      </view>
      <!-- 提示文字 -->
      <view>
        <view class="skip-hint">点击继续</view>
      </view>
    </view>
    <!-- 结局事件单独展示 -->
    <view wx:if="{{showResult && isEndingPending}}" class="result-panel ending">
      <view class="result-text">{{eventResult}}</view>
      <view class="attr-changes" wx:if="{{attrChanges.length > 0}}">
        <view class="attr-change-item {{item.delta > 0 ? 'add' : 'sub'}}" wx:for="{{attrChanges}}" wx:key="name">
          {{item.name}} {{item.delta > 0 ? '+' : ''}}{{item.delta}}
        </view>
      </view>
      <!-- 结局事件：显示查看结局按钮 -->
      <view class="ending-btn-wrap">
        <button class="ending-goto-btn" bindtap="goToResult">查看我的结局 →</button>
      </view>
    </view>

    <!-- 选项列表 -->
    <view wx:if="{{!showResult}}" class="options-list">
      <view class="option-item" wx:for="{{currentEvent.options}}" wx:key="index" 
            bindtap="selectOption" data-index="{{index}}">
        {{item.text}}
      </view>
    </view>
  </view>

  <!-- 游戏结束状态：直接跳转结局，不显示中间页 -->

  <!-- 内页全屏广告位（底部固定） -->
  <view class="game-ad-slot">
    <text class="ad-placeholder">游戏内广告位</text>
  </view>
</view>